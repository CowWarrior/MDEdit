<Window x:Class="MDEdit.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About MDEdit"
        Icon="Resources/AppIcon.ico"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <StackPanel Margin="24" Width="280">
        <Image Source="Resources/AppIcon.png" Width="64" Height="64" HorizontalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <TextBlock Text="MDEdit" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,12,0,0"/>
        <TextBlock Text="Markdown Editor" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        <TextBlock Text="Built with WPF and AvalonEdit" HorizontalAlignment="Center" Margin="0,2,0,0" Opacity="0.7"/>

        <TextBlock x:Name="VersionText" HorizontalAlignment="Center" Margin="0,16,0,0"/>
        <TextBlock x:Name="BuildDateText" HorizontalAlignment="Center" Margin="0,2,0,0" Opacity="0.7"/>

        <Button Content="OK" IsDefault="True" IsCancel="True" Click="BtnOk_Click"
                Width="80" HorizontalAlignment="Center" Margin="0,20,0,0" Padding="4"/>
    </StackPanel>
</Window>
