<?xml version="1.0" encoding="utf-8"?>
<!--
  Static ClickOnce settings only. ManifestCertificateThumbprint and ApplicationRevision are
  deliberately NOT set here — build/Publish-ClickOnce.ps1 resolves the signing cert by subject
  name at publish time (it rotates) and computes the revision from git history, so neither value
  is ever hardcoded or committed.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishProtocol>ClickOnce</PublishProtocol>
    <PublishDir>..\docs\</PublishDir>
    <PublishUrl>https://cowwarrior.github.io/MDEdit/</PublishUrl>
    <InstallUrl>https://cowwarrior.github.io/MDEdit/</InstallUrl>
    <UpdateUrl>https://cowwarrior.github.io/MDEdit/</UpdateUrl>
    <Install>true</Install>
    <UpdateEnabled>true</UpdateEnabled>
    <UpdateMode>Foreground</UpdateMode>
    <UpdateRequired>false</UpdateRequired>
    <MapFileExtensions>true</MapFileExtensions>
    <BootstrapperEnabled>false</BootstrapperEnabled>
    <GenerateManifests>true</GenerateManifests>
    <SignManifests>true</SignManifests>
    <ManifestTimestampUrl>http://timestamp.digicert.com</ManifestTimestampUrl>
    <ProductName>MDEdit</ProductName>
    <PublisherName>Maze</PublisherName>
    <ApplicationVersion>1.0.0.0</ApplicationVersion>
  </PropertyGroup>
</Project>
