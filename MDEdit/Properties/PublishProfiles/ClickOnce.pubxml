<?xml version="1.0" encoding="utf-8"?>
<!--
  Static ClickOnce settings only. ManifestCertificateThumbprint and ApplicationVersion are
  deliberately NOT meant to be used from here at publish time — build/Publish-ClickOnce.ps1
  resolves the signing cert by subject name (it rotates) and overrides ApplicationVersion with
  a value derived from git history, so neither is ever hardcoded or committed. The ApplicationVersion
  below is only a placeholder for tooling (e.g. VS's Publish UI) that reads this file directly.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishProtocol>ClickOnce</PublishProtocol>
    <PublishDir>..\docs\</PublishDir>
    <PublishUrl>https://cowwarrior.github.io/MDEdit/</PublishUrl>
    <InstallUrl>https://cowwarrior.github.io/MDEdit/</InstallUrl>
    <UpdateUrl>https://cowwarrior.github.io/MDEdit/</UpdateUrl>
    <Install>true</Install>
    <UpdateEnabled>true</UpdateEnabled>
    <UpdateMode>Foreground</UpdateMode>
    <UpdateRequired>false</UpdateRequired>
    <MapFileExtensions>true</MapFileExtensions>
    <BootstrapperEnabled>false</BootstrapperEnabled>
    <GenerateManifests>true</GenerateManifests>
    <SignManifests>true</SignManifests>
    <ManifestTimestampUrl>http://timestamp.digicert.com</ManifestTimestampUrl>
    <ProductName>MDEdit</ProductName>
    <PublisherName>Maze</PublisherName>
    <ApplicationVersion>1.0.0.0</ApplicationVersion>
  </PropertyGroup>

  <!--
    Associates .md/.markdown/.txt with MDEdit. DefaultIcon references the icon already embedded in
    MDEdit.exe (via ApplicationIcon in the csproj) rather than deploying a separate .ico file.
    Only takes effect on a fresh install, not on an update of an already-installed copy — a ClickOnce
    limitation, not something publishing again can fix.
  -->
  <ItemGroup>
    <FileAssociation Include=".md">
      <Description>Markdown Document</Description>
      <Progid>MDEdit.Document</Progid>
      <DefaultIcon>MDEdit.exe,0</DefaultIcon>
    </FileAssociation>
    <FileAssociation Include=".markdown">
      <Description>Markdown Document</Description>
      <Progid>MDEdit.Document</Progid>
      <DefaultIcon>MDEdit.exe,0</DefaultIcon>
    </FileAssociation>
    <FileAssociation Include=".txt">
      <Description>Text Document</Description>
      <Progid>MDEdit.Document</Progid>
      <DefaultIcon>MDEdit.exe,0</DefaultIcon>
    </FileAssociation>
  </ItemGroup>
</Project>
