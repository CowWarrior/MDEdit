<Window x:Class="MDEdit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MDEdit"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="MDEdit - Untitled"
        Height="720" Width="1100"
        MinHeight="400" MinWidth="600"
        Icon="Resources/AppIcon.ico"
        Closing="Window_Closing">

    <DockPanel>

        <!-- ═══ Menu bar ═══ -->
        <Menu DockPanel.Dock="Top" Padding="2"
              Background="{DynamicResource AppChromeBackgroundBrush}"
              Foreground="{DynamicResource AppChromeForegroundBrush}">
            <MenuItem Header="_File">
                <MenuItem Header="_New"         Command="New"                              InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open…"        Command="Open"                             InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Save"         Command="Save"                             InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As…"     Command="{x:Static local:MainWindow.SaveAsCommand}" InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="E_xit"         Command="Close"/>
            </MenuItem>

            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo"         Command="Undo"       InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo"         Command="Redo"       InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="Cu_t"          Command="Cut"        InputGestureText="Ctrl+X"/>
                <MenuItem Header="_Copy"         Command="Copy"       InputGestureText="Ctrl+C"/>
                <MenuItem Header="_Paste"        Command="Paste"      InputGestureText="Ctrl+V"/>
                <Separator/>
                <MenuItem Header="Select _All"   Command="SelectAll"  InputGestureText="Ctrl+A"/>
            </MenuItem>

            <MenuItem Header="F_ormat">
                <MenuItem Header="_Bold"         Command="{x:Static local:MainWindow.BoldCommand}"   InputGestureText="Ctrl+B"/>
                <MenuItem Header="_Italic"       Command="{x:Static local:MainWindow.ItalicCommand}" InputGestureText="Ctrl+I"/>
                <MenuItem Header="_Strikethrough" Click="BtnStrike_Click"/>
                <Separator/>
                <MenuItem Header="Heading _1"    Click="BtnH1_Click"         InputGestureText="Ctrl+1"/>
                <MenuItem Header="Heading _2"    Click="BtnH2_Click"         InputGestureText="Ctrl+2"/>
                <MenuItem Header="Heading _3"    Click="BtnH3_Click"         InputGestureText="Ctrl+3"/>
                <Separator/>
                <MenuItem Header="Inline _Code"  Click="BtnCode_Click"/>
                <MenuItem Header="Code _Block"   Click="BtnCodeBlock_Click"/>
                <MenuItem Header="_Link…"        Click="BtnLink_Click"/>
                <Separator/>
                <MenuItem Header="• Bullet List"    Click="BtnBulletList_Click"/>
                <MenuItem Header="1. Numbered List" Click="BtnNumberList_Click"/>
                <MenuItem Header="&gt; Blockquote"  Click="BtnBlockquote_Click"/>
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem x:Name="MenuWordWrap"    Header="_Word Wrap"    IsCheckable="True" Click="MenuWordWrap_Click"/>
                <MenuItem x:Name="MenuLineNumbers" Header="Line _Numbers" IsCheckable="True" IsChecked="True" Click="MenuLineNumbers_Click"/>
                <Separator/>
                <MenuItem Header="_Theme">
                    <MenuItem x:Name="MenuThemeLight"  Header="_Light"                    IsCheckable="True" Click="MenuThemeLight_Click"/>
                    <MenuItem x:Name="MenuThemeDark"   Header="_Dark"                     IsCheckable="True" Click="MenuThemeDark_Click"/>
                    <MenuItem x:Name="MenuThemeSystem" Header="_System (follow Windows)"  IsCheckable="True" Click="MenuThemeSystem_Click"/>
                </MenuItem>
                <MenuItem Header="Editor _Mode">
                    <MenuItem Header="_Syntax Highlighting" IsChecked="True" IsCheckable="True" IsEnabled="False"/>
                    <MenuItem Header="_WYSIWYG (coming soon)" IsCheckable="True" IsEnabled="False"/>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_Register File Associations (.md, .markdown, .txt)…" Click="MenuRegisterFileAssociations_Click"/>
                <Separator/>
                <MenuItem Header="_About MDEdit…" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- ═══ Toolbar ═══ -->
        <ToolBarTray DockPanel.Dock="Top" Background="{DynamicResource AppChromeBackgroundBrush}">
            <ToolBar Band="0" BandIndex="0"
                     Background="{DynamicResource AppChromeBackgroundBrush}"
                     Foreground="{DynamicResource AppChromeForegroundBrush}">

                <!-- Toolbar buttons get their style from ToolBar.ButtonStyleKey in the active
                     theme, which doesn't inherit the ToolBar's Foreground. An implicit TextBlock
                     style reaches both explicit TextBlock content and string content (rendered
                     via auto-generated TextBlocks), keeping labels readable in both themes. -->
                <ToolBar.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource AppChromeForegroundBrush}"/>
                    </Style>
                </ToolBar.Resources>

                <!-- Inline formatting -->
                <Button Command="{x:Static local:MainWindow.BoldCommand}"   ToolTip="Bold (Ctrl+B)">
                    <TextBlock FontWeight="Bold" Width="12" TextAlignment="Center">B</TextBlock>
                </Button>
                <Button Command="{x:Static local:MainWindow.ItalicCommand}" ToolTip="Italic (Ctrl+I)">
                    <TextBlock FontStyle="Italic" Width="12" TextAlignment="Center">I</TextBlock>
                </Button>
                <Button Click="BtnStrike_Click" ToolTip="Strikethrough">
                    <TextBlock TextDecorations="Strikethrough" Width="12" TextAlignment="Center">S</TextBlock>
                </Button>
                <Separator/>

                <!-- Headings -->
                <Button Click="BtnH1_Click" ToolTip="Heading 1 (Ctrl+1)" Padding="4,2">H1</Button>
                <Button Click="BtnH2_Click" ToolTip="Heading 2 (Ctrl+2)" Padding="4,2">H2</Button>
                <Button Click="BtnH3_Click" ToolTip="Heading 3 (Ctrl+3)" Padding="4,2">H3</Button>
                <Separator/>

                <!-- Insert -->
                <Button Click="BtnLink_Click"      ToolTip="Insert Link"       Padding="4,2">Link</Button>
                <Button Click="BtnCode_Click"      ToolTip="Inline Code"       Padding="4,2">` `</Button>
                <Button Click="BtnCodeBlock_Click" ToolTip="Code Block"        Padding="4,2">```</Button>
                <Separator/>

                <!-- Lists and blockquote -->
                <Button Click="BtnBulletList_Click"  ToolTip="Bullet List"    Padding="4,2">• List</Button>
                <Button Click="BtnNumberList_Click"  ToolTip="Numbered List"  Padding="4,2">1. List</Button>
                <Button Click="BtnBlockquote_Click"  ToolTip="Blockquote"     Padding="4,2">&gt; Quote</Button>

            </ToolBar>
        </ToolBarTray>

        <!-- ═══ Status bar ═══ -->
        <StatusBar DockPanel.Dock="Bottom" Height="22"
                   Background="{DynamicResource AppChromeBackgroundBrush}"
                   Foreground="{DynamicResource AppChromeForegroundBrush}">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel LastChildFill="True"/>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem DockPanel.Dock="Right" Margin="4,0">
                <TextBlock x:Name="StatusPosition">Ln 1, Col 1</TextBlock>
            </StatusBarItem>
            <Separator DockPanel.Dock="Right"/>
            <StatusBarItem>
                <TextBlock x:Name="StatusFileName">Untitled</TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ Editor ═══ -->
        <avalonEdit:TextEditor
            x:Name="Editor"
            FontFamily="Cascadia Code, Consolas, Courier New"
            FontSize="14"
            ShowLineNumbers="True"
            WordWrap="False"
            Background="{DynamicResource EditorBackgroundBrush}"
            Foreground="{DynamicResource EditorForegroundBrush}"
            LineNumbersForeground="{DynamicResource EditorLineNumberBrush}"
            Padding="8,4"/>

    </DockPanel>
</Window>
